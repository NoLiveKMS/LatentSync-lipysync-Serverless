{
  "title": "Latentsync lipsync",
  "description": "Latentsync lipsync with request-level routing between staging and production S3 buckets for input; outputs uploaded to Backblaze B2",
  "type": "serverless",
  "category": "video",

  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 50,

    "env": [
      {
        "key": "STAG_AWS_ACCESS_KEY_ID",
        "input": {
          "name": "Staging AWS Access Key",
          "type": "string",
          "secret": true
        }
      },
      {
        "key": "STAG_AWS_SECRET_ACCESS_KEY",
        "input": {
          "name": "Staging AWS Secret Key",
          "type": "string",
          "secret": true
        }
      },
      {
        "key": "STAG_S3_BUCKET",
        "input": {
          "name": "Staging S3 Bucket",
          "type": "string",
          "description": "S3 bucket for staging inputs"
        }
      },

      {
        "key": "PROD_AWS_ACCESS_KEY_ID",
        "input": {
          "name": "Production AWS Access Key",
          "type": "string",
          "secret": true
        }
      },
      {
        "key": "PROD_AWS_SECRET_ACCESS_KEY",
        "input": {
          "name": "Production AWS Secret Key",
          "type": "string",
          "secret": true
        }
      },
      {
        "key": "PROD_S3_BUCKET",
        "input": {
          "name": "Production S3 Bucket",
          "type": "string",
          "description": "S3 bucket for production inputs"
        }
      },

      {
        "key": "AWS_REGION",
        "value": "us-east-2"
      },

      {
        "key": "R2_ACCESS_KEY",
        "input": {
          "name": "Backblaze B2 Access Key",
          "type": "string",
          "secret": true,
          "description": "Backblaze B2 application key ID"
        }
      },
      {
        "key": "R2_SECRET_KEY",
        "input": {
          "name": "Backblaze B2 Secret Key",
          "type": "string",
          "secret": true,
          "description": "Backblaze B2 application key"
        }
      },
      {
        "key": "R2_BUCKET",
        "input": {
          "name": "Backblaze B2 Bucket Name",
          "type": "string",
          "description": "Bucket name for output video upload (e.g. RunPodmyfile)"
        }
      },
      {
        "key": "R2_ENDPOINT",
        "input": {
          "name": "Backblaze B2 S3 Endpoint",
          "type": "string",
          "description": "e.g. https://s3.us-east-005.backblazeb2.com"
        }
      },
      {
        "key": "R2_PUBLIC_BASE",
        "input": {
          "name": "Backblaze B2 Public Base URL",
          "type": "string",
          "description": "e.g. https://f005.backblazeb2.com/file/RunPodmyfile"
        }
      }
    ]
  }
}
